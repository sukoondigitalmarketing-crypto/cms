# =================================================================
# BuildCore CMS - Watertight GitIgnore Configuration
# Prevents accidental leaks of keys, credentials, db backups, and logs
# =================================================================

# ─────────────────────────────────────────────────────────────────
# 1. Dependency Directories
# ─────────────────────────────────────────────────────────────────
node_modules/
jspm_packages/
web_modules/

# ─────────────────────────────────────────────────────────────────
# 2. Environment Variables & Secrets (CRITICAL)
# ─────────────────────────────────────────────────────────────────
# Ignore all environment files which typically hold API keys and database credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
# Prevent general pattern leaks
.env*
# Explicitly allow the safe sample configuration template
!.env.example

# Private keys, certificates, and credentials
*.pem
*.key
*.pub
*.pfx
*.p12
*.cer
*.crt
credentials.json
client_secret*.json

# ─────────────────────────────────────────────────────────────────
# 3. Build & Distribution Directories
# ─────────────────────────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
.svelte-kit/

# ─────────────────────────────────────────────────────────────────
# 4. Databases, Local Backups, and Dumps
# ─────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.sql
*.dump
*.backup
*.rdb

# ─────────────────────────────────────────────────────────────────
# 5. Logs & Diagnostics
# ─────────────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─────────────────────────────────────────────────────────────────
# 6. IDEs, Editors & System Directories
# ─────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Editors
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────────
# 7. Testing, Scratch, and Temporary Directories
# ─────────────────────────────────────────────────────────────────
coverage/
tmp/
temp/
scratch/
.gemini/
antigravity-ide/
