# ═══════════════════════════════════════════════════════════════
# BuildCore CMS - Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# SECURITY NOTICE: 
# - Never commit actual credentials to version control
# - Copy this file to .env.local and fill in real values
# - All fields marked REQUIRED must be set
# - Never expose these values in frontend code

# ─────────────────────────────────────────────────────────────────
# FRONTEND (Vite) - Client-side
# ─────────────────────────────────────────────────────────────────

# Gemini API Key for AI features (frontend visible - use restricted keys only)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Initial admin email for first-time setup (dev only, not for production)
# IMPORTANT: In production, use Firebase Custom Claims instead
VITE_INITIAL_ADMIN_EMAIL=

# Root CEO email for frontend identification (should match ROOT_CEO_EMAIL)
VITE_ROOT_CEO_EMAIL=ceo@yourcompany.com

# ─────────────────────────────────────────────────────────────────
# BACKEND (Node.js Server) - Server-side ONLY
# ─────────────────────────────────────────────────────────────────

# MySQL Database Configuration (REQUIRED)
# All fields must be set - no defaults for security reasons
DB_HOST=your_database_host
DB_USER=your_database_user
DB_PASSWORD=your_secure_database_password
DB_NAME=your_database_name

# Root CEO Configuration (REQUIRED)
ROOT_CEO_EMAIL=ceo@yourcompany.com
ROOT_CEO_PASSWORD=your_secure_ceo_password

# CORS Configuration
# Comma-separated list of allowed origins (e.g., https://yourdomain.com,http://localhost:3000)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────────────────────────────

# Server port (optional, defaults to 3001 if not set)
PORT=3001

# Node environment
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────
# SETUP INSTRUCTIONS
# ─────────────────────────────────────────────────────────────────
#
# 1. Copy this file to .env.local and .env
# 
# 2. Configure Backend (REQUIRED):
#    DB_HOST, DB_USER, DB_PASSWORD, DB_NAME, ROOT_CEO_EMAIL, ROOT_CEO_PASSWORD
#    - Ensure MySQL is running locally or on configured host
#    - Database will be created automatically on first run
#    - Use strong passwords in production
#
# 3. Configure CORS (REQUIRED FOR PRODUCTION):
#    ALLOWED_ORIGINS should be set to your production domain(s)
#
# 4. Configure Frontend (Optional):
#    VITE_GEMINI_API_KEY
#    - Optional: Only required if using AI features
#    - Get from Google AI Studio
#
# 5. Production Deployment:
#    - Set NODE_ENV=production
#    - Remove VITE_INITIAL_ADMIN_EMAIL
#    - Use secure, unique database passwords
#    - Store credentials in deployment platform secrets
#
# ─────────────────────────────────────────────────────────────────
